# Supabase — cle publique (client navigateur + server)
# https://supabase.com/dashboard/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase — cle service role (server uniquement, NE JAMAIS exposer au client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase — connection string directe pour Drizzle (pooler PgBouncer si dispo)
# Format : postgresql://postgres.<ref>:<password>@<host>:6543/postgres
DATABASE_URL=postgresql://postgres:password@localhost:5432/postgres
