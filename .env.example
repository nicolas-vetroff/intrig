# Supabase — valeurs fournies par `npx supabase start` (dev local).
# Pour la prod, remplacer par les cles du projet Supabase cloud.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi... # voir sortie de `supabase start`

# Cle service role (server uniquement, NE JAMAIS exposer au client).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi... # voir sortie de `supabase start`

# Postgres local expose par le CLI Supabase.
# En prod, utiliser le transaction pooler : postgresql://postgres.<ref>:<password>@<host>:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Origine publique de l'app (utilise pour emailRedirectTo du magic link).
# En dev : http://127.0.0.1:3000 (ou 3030 si tu as change le port dans package.json).
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Liste d'emails autorises a acceder au dashboard / creation / edition
# de livres. Separes par virgule. Zero migration DB, edite juste cette var
# et relance l'app. Quand la creation sera ouverte aux lecteurs, cette var
# ne sera plus utilisee que pour des privileges reellement admin.
ADMIN_EMAILS=toi@example.com
