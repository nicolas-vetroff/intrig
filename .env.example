# Supabase — values printed by `npx supabase start` (local dev).
# For production, replace with the keys from the Supabase cloud project.
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi... # see `supabase start` output

# Service-role key (server only — NEVER expose to the client).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi... # see `supabase start` output

# Local Postgres exposed by the Supabase CLI.
# In production, use the transaction pooler:
# postgresql://postgres.<ref>:<password>@<host>:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Public origin of the app (used for emailRedirectTo on magic links).
# In dev: must match `next dev -p <port>` from package.json (3030 by default).
NEXT_PUBLIC_SITE_URL=http://localhost:3030

# Comma-separated list of emails allowed to access the dashboard /
# creation / edit of books. Zero DB migrations needed — just edit this
# var and restart the app. Once book creation opens up to readers, this
# var will only be used for truly admin-only privileges.
ADMIN_EMAILS=you@example.com

# Public feedback inbox. Rendered as a `mailto:` link in the footer and
# on the landing — NEXT_PUBLIC_ because the URL needs to reach the
# client bundle. Leave empty to hide the feedback links entirely.
NEXT_PUBLIC_FEEDBACK_EMAIL=feedback@example.com
